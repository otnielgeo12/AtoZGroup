# Local dev override — makes all fetch() calls use relative paths
# so Vite's dev proxy handles routing:
#   /api/v1/crm/* → http://localhost:5000  (local in-memory CRM dummy)
#   /api/*        → https://api.atozgroupsemarang.com  (production, all other routes)
#
# DO NOT commit this file — it overrides .env only for local development.
VITE_API_URL=
